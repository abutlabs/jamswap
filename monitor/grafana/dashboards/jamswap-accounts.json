    {
      "type": "timeseries",
      "title": "Order funnel (per min)",
      "id": 75,
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(jamswap_submits_total[5m])) * 60",
          "legendFormat": "submitted",
          "refId": "A"
        },
        {
          "expr": "sum(rate(jamswap_settled_total[5m])) * 60",
          "legendFormat": "settled",
          "refId": "B"
        },
        {
          "expr": "sum(rate(jamswap_refused_total[5m])) * 60",
          "legendFormat": "refused (backpressure)",
          "refId": "C"
        },
        {
          "expr": "sum(rate(jamswap_settle_timeouts_total[5m])) * 60",
          "legendFormat": "timed out",
          "refId": "D"
        },
        {
          "expr": "sum(rate(jamswap_settle_reverted_total[5m])) * 60",
          "legendFormat": "REVERTED (re-org)",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 4,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "settled"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#199e70"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "REVERTED (re-org)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#e66767"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Resting book depth",
