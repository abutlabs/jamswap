  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "lasair node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(lasair_block_height, node)",
        "refresh": 2,
        "current": {
          "text": "lm3",
          "value": "lm3"
        },
        "sort": 1,
        "includeAll": false,
        "multi": false
