    {
      "type": "timeseries",
      "title": "Order funnel (per 5m) \u2014 dex submits once; node-side stages count all 3 lm nodes",
      "id": 51,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(jamswap_submits_total{op=~\"register|deposit|withdraw|cancel\"}[5m]))",
          "legendFormat": "submitted (dex)",
          "refId": "A"
        },
        {
          "expr": "sum(increase(lasair_ce133_queued_total[5m]))",
          "legendFormat": "queued (3x)",
          "refId": "B"
        },
        {
          "expr": "sum(increase(lasair_ce133_guaranteed_total[5m]))",
          "legendFormat": "guaranteed",
          "refId": "C"
        },
        {
          "expr": "sum(increase(lasair_ce133_accumulated_total[5m]))",
          "legendFormat": "accumulated",
          "refId": "D"
        },
        {
          "expr": "sum(increase(jamswap_settled_total[5m]))",
          "legendFormat": "settled (dex)",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 4,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "submitted (dex)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#c98500"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "queued (3x)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#9085e9"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
