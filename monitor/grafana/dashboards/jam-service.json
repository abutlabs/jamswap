      "targets": [
        {
          "expr": "clamp_min(sum(jamswap_submits_total{op=~\"register|deposit|withdraw|cancel\"}) - sum(jamswap_settled_total) - sum(jamswap_settle_timeouts_total), 0)",
          "instant": true,
          "refId": "A"
