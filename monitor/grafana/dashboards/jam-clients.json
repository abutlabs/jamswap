{
  "uid": "jam-clients",
  "title": "JAM clients (averages)",
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "editable": true,
  "panels": [
    {
      "type": "stat",
      "title": "lasair \u2014 blocks/min (avg per validator)",
      "id": 20,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "avg(rate(lasair_blocks_authored_total[5m])) * 60",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "#c98500"
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value"
      }
    },
