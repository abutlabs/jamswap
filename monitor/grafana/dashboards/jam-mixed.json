      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 4,
            "showPoints": "never"
          },
          "color": {
            "mode": "palette-classic"
          },
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "pj0"
            },
            "properties": [
              {
                "id": "color",
